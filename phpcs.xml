<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/squizlabs/php_codesniffer/phpcs.xsd">

    <arg name="basepath" value="."/>
    <arg name="cache" value=".phpcs-cache"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="80"/>

    <!-- Show progress -->
    <arg value="p"/>

    <!-- Paths to check -->
    <file>src/Auth</file>
    <file>src/Bootstrap</file>
    <file>src/Configuration</file>
    <file>src/Console</file>
    <file>src/Contracts</file>
    <file>src/Factory</file>
    <file>src/Helpers</file>
    <file>src/Http</file>
    <file>src/Migration</file>
    <file>src/Pipeline</file>
    <file>src/Providers</file>
    <file>src/Proxy</file>
    <file>src/Scheduler</file>
    <file>src/Support</file>
    <file>src/Traits</file>
    <file>src/View</file>
    <file>src/Application.php</file>

    <!-- Include rules from the Qubus Coding Standard -->
    <rule ref="QubusCodingStandard"/>
</ruleset>
